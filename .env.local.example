# 硅基流动 API Key（分析衣服图片用）
# 注册获取：https://siliconflow.cn
SILICONFLOW_API_KEY=填入你的硅基流动 API key

# 火山引擎 API Key（生成模特图用）
# 注册获取：https://console.volcengine.com/ark → 开通即梦 Seedream
ARK_API_KEY=填入你的火山引擎 API key

# 分析模型（可不改）
ANALYSIS_MODEL=Qwen/Qwen3-VL-32B-Instruct

# 生图模型（可不改）
IMAGE_MODEL=doubao-seedream-4-5-251128

# 服务器绑定地址，本地用 127.0.0.1，部署用 0.0.0.0
HOST=127.0.0.1
